data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
# Environment & secrets
.env
.env.local
*.key
# IDE & OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
# Jupyter
.ipynb_checkpoints/
# Logs & results (regeneratable)
*.log
results/*.png
results/*.csv
results/*.json
wandb/
# Personal / AI Context Files (DO NOT COMMIT)
ANTIGRAVITY_CONTEXT.md
interview_prep_qa.md
