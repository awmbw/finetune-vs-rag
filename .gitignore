# Python bytecode & cache
__pycache__/
*.py[cod]
*.so
# Virtual environments
venv/
.venv/
env/
# Distribution & build
build/
dist/
*.egg-info/
# Model files — NEVER commit these (too large)
*.bin
*.safetensors
*.gguf
*.pt
*.pth
*.onnx
models/
